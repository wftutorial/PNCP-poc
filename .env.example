# ============================================
# Synkra AIOS Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# LLM Providers
# --------------------------------------------

# DeepSeek API (for claude-free command)
# Get your key at: https://platform.deepseek.com/api_keys
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=

# OpenRouter API (for multi-model routing)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic API (direct, if not using Claude Max subscription)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --------------------------------------------
# LLM Arbiter Configuration (STORY-179)
# --------------------------------------------
# GPT-4.1-nano for false positive elimination (migrated from gpt-4o-mini in GTM-FIX-028)
# Cost: ~R$ 0.00003 per classification (~R$ 0.50/month for 10K contracts)

# Feature flag to enable/disable LLM arbiter
LLM_ARBITER_ENABLED=true

# LLM model for contract classification
LLM_ARBITER_MODEL=gpt-4.1-nano

# Max tokens for LLM output (1 token = "SIM" or "NAO")
LLM_ARBITER_MAX_TOKENS=1

# Temperature (0 = deterministic, 1 = creative)
LLM_ARBITER_TEMPERATURE=0

# OpenAI client timeout in seconds (DEBT-103 AC1/AC9)
# GPT-4.1-nano p99 ≈ 1s; 5s = 5× p99. Prevents thread starvation on LLM hangs.
# Also configurable via legacy alias LLM_TIMEOUT_S.
OPENAI_TIMEOUT_S=5

# Arbiter LRU cache max entries (DEBT-103 AC3/AC9)
# In-memory OrderedDict with LRU eviction. Prevents unbounded memory growth.
LRU_MAX_SIZE=5000

# Term density thresholds (can be adjusted without code changes)
# High threshold: density > X% = auto-accept (no LLM)
TERM_DENSITY_HIGH_THRESHOLD=0.05  # 5%

# Low threshold: density < X% = auto-reject (no LLM)
TERM_DENSITY_LOW_THRESHOLD=0.01   # 1%

# Synonym matching feature flag (STORY-179 AC12)
SYNONYM_MATCHING_ENABLED=true

# Zero results relaxation feature flag (STORY-179 AC14)
ZERO_RESULTS_RELAXATION_ENABLED=true

# --------------------------------------------
# Search & Research Tools
# --------------------------------------------

# Exa Search API (web search for agents)
# Get your key at: https://exa.ai/
EXA_API_KEY=

# Context7 (library documentation lookup)
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=

# --------------------------------------------
# Database & Backend
# --------------------------------------------

# Supabase (database, auth, storage)
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Required. JWT secret from Supabase dashboard > Settings > API > JWT Secret
# Used for verifying JWTs server-side (auth.py, authorization.py)
SUPABASE_JWT_SECRET=

# --------------------------------------------
# Logging (STORY-220)
# --------------------------------------------
# Log output format: "json" (production default) or "text" (dev default)
# JSON is required for structured log queries in Railway/Datadog/etc.
LOG_FORMAT=
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# --------------------------------------------
# Version Control & CI/CD
# --------------------------------------------

# GitHub Token (for GitHub CLI and API access)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --------------------------------------------
# Project Management
# --------------------------------------------

# ClickUp API (if using ClickUp integration)
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=

# --------------------------------------------
# Automation & Workflows
# --------------------------------------------

# N8N (workflow automation)
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=

# --------------------------------------------
# Monitoring & Analytics
# --------------------------------------------

# Mixpanel (product analytics) — STORY-219
# Create project at: https://mixpanel.com/ (separate projects for prod/dev)
# Frontend-only: exposes token in browser (this is normal for Mixpanel)
NEXT_PUBLIC_MIXPANEL_TOKEN=
# Set to "true" to enable analytics tracking (requires valid token above)
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Organizations/Teams feature flag (UX-406)
# Controls org membership fetch and team/personal toggle on dashboard
# Keep false until backend org endpoints are implemented
NEXT_PUBLIC_ORGS_ENABLED=false

# Sentry (error tracking) — STORY-211
# Create projects at: https://sentry.io/
# Backend: Python (FastAPI) project → get DSN
# Frontend: JavaScript (Next.js) project → get DSN + auth token
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_ENVIRONMENT=production

# --------------------------------------------
# OpenTelemetry Tracing (CRIT-023 + CRIT-025)
# --------------------------------------------
# OTLP base endpoint for trace export. Leave empty to disable tracing (no-op mode).
# For Grafana Cloud: https://otlp-gateway-prod-<region>.grafana.net/otlp
# The SDK auto-appends /v1/traces to OTEL_EXPORTER_OTLP_ENDPOINT.
# Free tier includes 50GB traces/month.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Signal-specific traces endpoint (RECOMMENDED over OTEL_EXPORTER_OTLP_ENDPOINT).
# When set, the SDK uses this URL as-is (no /v1/traces auto-append).
# For Grafana Cloud: https://otlp-gateway-prod-<region>.grafana.net/otlp/v1/traces
# This is more explicit and avoids ambiguity about auto-append behavior.
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
# Auth headers for OTLP endpoint. Format: "key=value" (URL-encoded values, comma-separated).
# For Grafana Cloud: Authorization=Basic%20<base64(instanceId:cloudApiToken)>
# Generate base64: echo -n "instanceId:cloudApiToken" | base64
# The SDK URL-decodes values (%20 → space) before sending.
OTEL_EXPORTER_OTLP_HEADERS=
# Service name shown in Grafana/Jaeger trace explorer (default: smartlic-backend)
OTEL_SERVICE_NAME=smartlic-backend
# Sampling rate: 0.0 (none) to 1.0 (all). Default 0.1 = 10% of requests traced.
# Start with 0.1 to control volume; increase if needed for debugging.
OTEL_SAMPLING_RATE=0.1

# --------------------------------------------
# Prometheus Metrics (GTM-RESILIENCE-E03)
# --------------------------------------------
# Enable/disable Prometheus /metrics endpoint (default: true)
METRICS_ENABLED=true
# Bearer token to protect /metrics. Leave empty for unauthenticated access.
METRICS_TOKEN=
# Bearer token to protect /docs and /redoc (SYS-036). Leave empty for open access.
DOCS_ACCESS_TOKEN=

# --------------------------------------------
# Portal de Compras Públicas — PCP (GTM-FIX-011)
# --------------------------------------------
# API key for Portal de Compras Públicas.
# Request at: https://bibliotecapcp.zendesk.com/hc/pt-br/articles/4593549708570
# Base URL: https://apipcp.portaldecompraspublicas.com.br
# Auth: publicKey parameter in URL (not header)
PCP_PUBLIC_KEY=
# Enable PCP as procurement data source (default: true when key is set)
PCP_ENABLED=true
# Request timeout in seconds
PCP_TIMEOUT=30
# Rate limit: requests per second (start conservative)
PCP_RATE_LIMIT_RPS=5

# --------------------------------------------
# Portal da Transparência — CGU (STORY-254)
# --------------------------------------------
# Free API key from Gov.br (requires verified Gov.br account)
# Register at: https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
# Rate limit: 90 req/min (06h-24h), 300 req/min (00h-06h)
PORTAL_TRANSPARENCIA_API_KEY=
# Enable Portal da Transparência as procurement data source
ENABLE_SOURCE_PORTAL_TRANSPARENCIA=false

# --------------------------------------------
# Querido Diário — Diários Oficiais Municipais (STORY-255)
# --------------------------------------------
# Free API, no auth required. Covers ~1,047 municipalities.
# Returns unstructured gazette text; requires LLM for extraction.
# API docs: https://api.queridodiario.ok.org.br/docs
ENABLE_SOURCE_QUERIDO_DIARIO=false

# --------------------------------------------
# Cloud Providers
# --------------------------------------------

# Railway (deployment)
RAILWAY_TOKEN=

# Gunicorn Configuration (CRIT-010)
# --preload loads ASGI app in master before forking workers,
# eliminating 404s during startup when workers are still importing modules.
GUNICORN_PRELOAD=true

# Vercel (deployment)
VERCEL_TOKEN=

# --------------------------------------------
# Application Version (GTM-GO-003 AC4)
# --------------------------------------------
# Injected by CI/CD at deploy time. Populates /health version field.
# Format: vX.Y.Z (e.g., v0.5.0). Default: "dev" (local development).
APP_VERSION=dev

# --------------------------------------------
# AIOS Core Configuration
# --------------------------------------------
NODE_ENV=development
AIOS_VERSION=2.2.0

# --------------------------------------------
# Circuit Breaker Configuration (GTM-FIX-005)
# --------------------------------------------
# Per-source circuit breakers prevent cascading failures.
# Failures in one source (PNCP) won't block another (PCP).

# PNCP: 27 UFs × 4 modalities = 108 parallel slots. 18% failure ≈ 20 hits.
# Default 50 prevents a single user's bad search from tripping the global breaker.
PNCP_CIRCUIT_BREAKER_THRESHOLD=50
PNCP_CIRCUIT_BREAKER_COOLDOWN=120

# PCP (Portal de Compras Públicas): More conservative — API stability unknown.
PCP_CIRCUIT_BREAKER_THRESHOLD=30
PCP_CIRCUIT_BREAKER_COOLDOWN=120

# --------------------------------------------
# Timeout Chain (GTM-RESILIENCE-F03)
# --------------------------------------------
# Per-modality timeout in seconds. Must be strictly < PNCP_TIMEOUT_PER_UF.
# Default 60s covers ~6000 items/modality (120 pages × 50 items/page).
# Hierarchy: FE(480) > Pipeline(360) > Consolidation(300) > PerSource(180) > PerUF(90) > PerModality(60) > HTTP(30)
PNCP_TIMEOUT_PER_MODALITY=60

# Per-UF timeout in seconds. Must be > PNCP_TIMEOUT_PER_MODALITY + 30s margin.
# PNCP_TIMEOUT_PER_UF=90
# PNCP_TIMEOUT_PER_UF_DEGRADED=120

# --------------------------------------------
# Rate Limiting (GTM-GO-002)
# --------------------------------------------
# Feature flag to enable/disable all rate limits (default: true)
RATE_LIMITING_ENABLED=true
# Max searches per minute per authenticated user (default: 10)
SEARCH_RATE_LIMIT_PER_MINUTE=10
# Max login attempts per IP per 5 minutes (default: 5)
AUTH_RATE_LIMIT_PER_5MIN=5
# Max signup attempts per IP per 10 minutes (default: 3)
SIGNUP_RATE_LIMIT_PER_10MIN=3
# Max simultaneous SSE connections per user (default: 3)
SSE_MAX_CONNECTIONS=3

# --------------------------------------------
# Security (GTM-GO-006)
# --------------------------------------------
# Security scans for CRITICAL vulnerabilities are BLOCKING in CI.
# - Frontend: npm audit --audit-level=critical (tests.yml)
# - Backend: pip-audit --strict (backend-ci.yml)
# - Trivy: --severity CRITICAL --exit-code 1 (pr-validation.yml)
# HIGH/MEDIUM scans run as non-blocking warnings.
# See .github/workflows/ for thresholds and configuration.

# --------------------------------------------
# Periodic Cache Refresh (CRIT-032)
# --------------------------------------------
# Enable periodic cache refresh via ARQ cron job (default: false)
# When enabled, worker refreshes stale HOT/WARM entries and empty caches every N hours
CACHE_REFRESH_ENABLED=false
# Interval between refresh cycles in hours (default: 12 → runs at 00:00 + 12:00 UTC)
CACHE_REFRESH_INTERVAL_HOURS=12
# Max cache entries to refresh per cycle (default: 25)
CACHE_REFRESH_BATCH_SIZE=25
# Delay between consecutive entry dispatches in seconds (default: 5)
CACHE_REFRESH_STAGGER_SECONDS=5

# --------------------------------------------
# Startup Cache Warm-up (P1.2)
# --------------------------------------------
# Enable pre-warming top sector+UF combinations on startup (default: true)
# Pre-warming ensures trial users get <5s responses on their first search.
# Set to false to disable warm-up entirely (e.g. during load testing).
WARMUP_ENABLED=true
# Comma-separated UF codes to pre-warm (default: top 5 states by bid volume)
WARMUP_UFS=SP,RJ,MG,BA,PR
# Comma-separated sector IDs to pre-warm (default: top 5 sectors)
WARMUP_SECTORS=software,informatica,engenharia,saude,facilities
# Seconds to wait after boot before starting warm-up (default: 120s — lets app stabilize)
WARMUP_STARTUP_DELAY_SECONDS=120
# Seconds between consecutive warm-up dispatches (rate-limiting, default: 2s)
WARMUP_BATCH_DELAY_SECONDS=2

# --------------------------------------------
# Trial Email Sequence (STORY-310 / CRIT-044)
# --------------------------------------------
# Master switch for trial emails. Controls the STORY-310 email sequence
# (8 emails over 14 days: welcome, engagement, tips, urgency, expiring,
# last_day, expired). The legacy STORY-266 milestone system was removed
# in CRIT-044 — this is the only trial email system.
TRIAL_EMAILS_ENABLED=true

# --------------------------------------------
# Search Results TTL (STORY-362)
# --------------------------------------------
# In-memory L1 TTL is hardcoded at 3600s (1h) in routes/search.py
# Redis L2 TTL in seconds (default: 14400 = 4 hours)
RESULTS_REDIS_TTL=14400
# Supabase L3 TTL in hours (default: 24 = 24 hours)
RESULTS_SUPABASE_TTL_HOURS=24

# --------------------------------------------
# Stripe Billing (required in production)
# --------------------------------------------
# STRIPE_SECRET_KEY=sk_live_xxx          # Stripe API secret key (Dashboard > Developers > API keys)
# STRIPE_WEBHOOK_SECRET=whsec_xxx        # Webhook signing secret (Dashboard > Developers > Webhooks > Signing secret)

# --------------------------------------------
# Custom Configuration
# --------------------------------------------
# Add your custom API keys below
