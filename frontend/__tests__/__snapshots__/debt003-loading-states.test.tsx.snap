              class="absolute inset-0 -translate-x-full animate-shimmer bg-gradient-to-r from-transparent via-white/10 to-transparent"
            />
          </div>
          <div
            class="flex gap-2"
          >
            <div
              class="relative overflow-hidden bg-[var(--surface-1)] h-5 w-10 rounded-full"
            >
              <div
                class="absolute inset-0 -translate-x-full animate-shimmer bg-gradient-to-r from-transparent via-white/10 to-transparent"
              />
            </div>
            <div
              class="relative overflow-hidden bg-[var(--surface-1)] h-5 w-16 rounded-full"
            >
              <div
                class="absolute inset-0 -translate-x-full animate-shimmer bg-gradient-to-r from-transparent via-white/10 to-transparent"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;
