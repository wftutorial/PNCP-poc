{
  "__meta": "STORY-351 AC8: Grafana dashboard for filter discard rate monitoring",
  "dashboard": {
    "title": "SmartLic — Filter Discard Rate",
    "uid": "smartlic-discard-rate",
    "tags": ["smartlic", "filtering", "story-351"],
    "timezone": "browser",
    "refresh": "5m",
    "panels": [
      {
        "title": "Overall Discard Rate (30d Moving Avg)",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "1 - (sum(rate(smartlic_filter_output_total[30d])) / sum(rate(smartlic_filter_input_total[30d])))",
            "legendFormat": "Discard Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "orange", "value": 0.7 },
                { "color": "green", "value": 0.85 }
              ]
            },
            "min": 0,
            "max": 1
          }
        }
      },
      {
        "title": "Discard Rate Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.5, rate(smartlic_filter_discard_rate_bucket[1h]))",
            "legendFormat": "Median Discard Rate"
          },
          {
            "expr": "histogram_quantile(0.95, rate(smartlic_filter_discard_rate_bucket[1h]))",
            "legendFormat": "P95 Discard Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit"
          }
        }
      },
      {
        "title": "Discard Rate by Sector",
        "type": "bargauge",
        "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "1 - (sum by (sector) (rate(smartlic_filter_output_total[24h])) / sum by (sector) (rate(smartlic_filter_input_total[24h])))",
            "legendFormat": "{{sector}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "orange", "value": 0.7 },
                { "color": "green", "value": 0.85 }
              ]
            }
          }
        }
      },
      {
        "title": "Filter Input vs Output (24h)",
        "type": "timeseries",
        "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(smartlic_filter_input_total[5m])) * 300",
            "legendFormat": "Input (bids/5min)"
          },
          {
            "expr": "sum(rate(smartlic_filter_output_total[5m])) * 300",
            "legendFormat": "Output (passed/5min)"
          }
        ]
      }
    ]
  },
  "alertRules": [
    {
      "name": "Discard Rate Below 70%",
      "condition": "1 - (sum(rate(smartlic_filter_output_total[30d])) / sum(rate(smartlic_filter_input_total[30d]))) < 0.70",
      "for": "1h",
      "severity": "warning",
      "annotations": {
        "summary": "Filter discard rate dropped below 70% — 'a maioria' claim may not hold",
        "description": "The 30-day average filter discard rate is below 70%. Review sectors_data.yaml keywords and exclusions. STORY-351 AC8."
      }
    }
  ]
}
